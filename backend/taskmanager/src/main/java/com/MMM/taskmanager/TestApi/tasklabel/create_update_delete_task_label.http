### POST attach label to task - success
POST {{baseUrl}}/tasks/{{taskId}}/labels
Authorization: {{token}}
Content-Type: application/json

{
  "labelId": 2
}

###

### POST attach label to task - already attached (expect 409)
POST {{baseUrl}}/tasks/{{taskId}}/labels
Authorization: {{token}}
Content-Type: application/json

{
  "labelId": 2
}

###

### POST attach label to task - label not in same project (expect 400)
POST {{baseUrl}}/tasks/{{taskId}}/labels
Authorization: {{token}}
Content-Type: application/json

{
  "labelId": 8
}

###

### POST attach label to task - task not found (expect 404)
POST {{baseUrl}}/tasks/9999/labels
Authorization: {{token}}
Content-Type: application/json

{
  "labelId": 1
}

###

### POST attach label to task - label not found (expect 404)
POST {{baseUrl}}/tasks/{{taskId}}/labels
Authorization: {{token}}
Content-Type: application/json

{
  "labelId": 9999
}

###

### DELETE detach label from task - success
DELETE {{baseUrl}}/tasks/{{taskId}}/labels/2
Authorization: {{token}}

###

### DELETE detach label from task - not attached (expect 404)
DELETE {{baseUrl}}/tasks/{{taskId}}/labels/9999
Authorization: {{token}}

###

### DELETE detach label from task - task not found (expect 404)
DELETE {{baseUrl}}/tasks/9999/labels/1
Authorization: {{token}}